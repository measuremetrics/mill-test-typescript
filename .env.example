# PostgreSQL Database Configuration
# Copy this file to .env and update with your database settings

# Database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=password

# Test database settings (optional, for running tests)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=ecommerce_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=password